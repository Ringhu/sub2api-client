# Point this at your sub2api-style reverse proxy's OpenAI-compatible endpoint.
# Examples: https://your-proxy-domain.example.com/v1, http://localhost:8000/v1
OPENAI_BASE_URL=https://your-proxy-domain.example.com/v1

# Paste the API key issued by your proxy here.
OPENAI_API_KEY=sk-xxxxxxxx

# Some third-party libraries read OPENAI_API_BASE instead. Keep both in sync.
OPENAI_API_BASE=https://your-proxy-domain.example.com/v1
